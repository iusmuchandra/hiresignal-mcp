{
  "name": "hiresignal-mcp",
  "version": "0.2.0",
  "description": "Hiring-intent signal API for B2B sales/GTM. Turn live job postings into buying signals from any AI agent.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "hiresignal-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "ingest": "node dist/ingest.js",
    "ingest:dev": "tsx src/ingest.ts",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.ts'",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.0.4",
    "express": "4.21.2",
    "undici": "7.2.0",
    "zod": "3.24.1",
    "zod-to-json-schema": "3.24.1"
  },
  "devDependencies": {
    "@types/express": "5.0.0",
    "@types/node": "22.10.5",
    "@typescript-eslint/eslint-plugin": "8.19.1",
    "@typescript-eslint/parser": "8.19.1",
    "eslint": "9.17.0",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "jobs",
    "hiring",
    "recruiting",
    "claude",
    "ai-agent"
  ],
  "license": "MIT"
}
