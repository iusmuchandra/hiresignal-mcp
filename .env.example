# --- Required: at least one job data provider ---
SERPAPI_KEY=your_serpapi_key_here
JSEARCH_RAPIDAPI_KEY=your_rapidapi_key_here

# --- Auth: comma-separated allowlist of API keys clients must present ---
# If unset, the server runs in OPEN MODE (any caller can use it). Always set
# this before exposing the server to the network.
HIRESIGNAL_API_KEYS=

# --- Server ---
PORT=3000
